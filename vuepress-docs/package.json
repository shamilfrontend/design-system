{
  "name": "design-system-docs",
  "version": "0.1.0",
  "private": false,
  "description": "Design System Docs",
  "author": {
    "name": "ShamilFrontend"
  },
  "scripts": {
    "postinstall": "patch-package",
    "docs:dev": "node ../scripts/prepare-docs-demos.mjs && vuepress dev docs",
    "docs:build": "node ../scripts/prepare-docs-demos.mjs && vuepress build docs",
    "docs:analyze": "ANALYZE=true vuepress build docs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vuepress/bundler-vite": "2.0.0-rc.30",
    "@vuepress/theme-default": "2.0.0-rc.30",
    "patch-package": "^8.0.1",
    "rollup-plugin-visualizer": "^5.14.0",
    "vitest": "^3.2.4",
    "vue": "^3.5.0",
    "vuepress": "2.0.0-rc.30"
  },
  "resolutions": {
    "@vuepress/helper": "2.0.0-rc.30",
    "@vuepress/plugin-active-header-links": "2.0.0-rc.30",
    "@vuepress/plugin-back-to-top": "2.0.0-rc.30",
    "@vuepress/plugin-copy-code": "2.0.0-rc.30",
    "@vuepress/plugin-git": "2.0.0-rc.30",
    "@vuepress/plugin-links-check": "2.0.0-rc.30",
    "@vuepress/plugin-markdown-container": "2.0.0-rc.30",
    "@vuepress/plugin-medium-zoom": "2.0.0-rc.30",
    "@vuepress/plugin-nprogress": "2.0.0-rc.30",
    "@vuepress/plugin-palette": "2.0.0-rc.30",
    "@vuepress/plugin-prismjs": "2.0.0-rc.30",
    "@vuepress/plugin-seo": "2.0.0-rc.30",
    "@vuepress/plugin-sitemap": "2.0.0-rc.30",
    "@vuepress/plugin-theme-data": "2.0.0-rc.30"
  },
