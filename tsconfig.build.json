{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": ".",
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.build.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/**/*.d.ts", "types/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "stories",
    "site",
    "storybook-static",
    "vuepress-docs",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
