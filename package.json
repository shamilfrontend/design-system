{
  "name": "@shamilfrontend/design-system",
  "version": "0.0.1",
  "private": false,
  "description": "Design system for Web (vue 3)",
  "author": {
    "name": "ShamilFrontend"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "build:styles": "node scripts/compile-styles.mjs",
    "build:types": "node scripts/compile-dts.mjs",
    "serve": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint:js": "eslint '**/*.{vue,ts}'",
    "lint:js:fix": "eslint --fix '**/*.{vue,ts,html}'",
    "lint:style": "stylelint '**/*.{css,scss,vue}'",
    "lint:style:fix": "stylelint --fix '**/*.{css,scss,vue}'",
    "prettier": "prettier --check --ignore-unknown '**/*'",
    "prettier:fix": "prettier --write --ignore-unknown '**/*'",
    "format": "yarn lint:style:fix && yarn lint:js:fix && yarn prettier:fix",
    "test": "vitest",
    "test:c": "vitest --run --coverage",
    "type-check": "vue-tsc --noEmit",
    "prepare": "husky",
    "release": "release-it"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "async-validator": "^4.2.5",
    "colord": "^2.9.3",
    "date-fns": "^4.4.0",
    "focus-visible": "^5.2.1",
    "lodash-es": "^4.18.1",
    "object-hash": "^3.0.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-links": "^10.4.4",
    "@storybook/vue3-vite": "^10.4.4",
    "storybook": "^10.4.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.5",
    "@types/object-hash": "^2.2.1",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/test-utils": "^2.4.11",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.61.0",
    "vue-eslint-parser": "^10.2.0",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.4",
    "release-it": "^15.0.0",
    "rollup-plugin-copy": "^3.5.0",
    "sass": "^1.101.0",
    "sass-embedded": "^1.100.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.4"
  },
  "files": ["dist"],
  "sideEffects": false,
  "main": "./dist/design-system.umd.js",
  "module": "./dist/src/components/index.js",
  "style": "./dist/design-system.css",
  "types": "./dist/src/components/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/components/index.js",
      "require": "./dist/design-system.umd.js"
    },
    "./styles": "./dist/design-system.css",
    "./css/*": "./dist/css/*.css",
    "./fonts": "./dist/fonts/fonts.css",
    "./icons": "./dist/icons/icons.css"
  },
  "bugs": {
    "url": "https://github.com/shamilfrontend/design-system/issues"
  },
  "homepage": "https://github.com/shamilfrontend/design-system#readme",
  "keywords": [
    "design-system",
    "ui kit",
    "components",
    "library",
    "ui",
    "vue",
    "vue 3",
    "sass",
    "typescript"
  ],
  "license": "MIT",
  "maintainers": [
    {
      "name": "Shamil Alisultanov",
      "url": "https://github.com/shamilfrontend"
    }
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shamilfrontend/design-system"
  }
}
